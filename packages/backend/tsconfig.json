{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@peer/shared": ["../shared/src/index.ts"],
      "@peer/shared/*": ["../shared/src/*"]
    }
