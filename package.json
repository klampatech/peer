{
  "name": "peer",
  "version": "1.0.0",
  "private": true,
  "description": "P2P VoIP Web Application with WebRTC mesh",
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "load:test": "k6 run tests/load/turn-server-load-test.js",
    "load:test:http": "k6 run tests/load/http-load-test.js",
    "load:test:ws": "k6 run tests/load/websocket-load-test.js",
    "load:test:signalling": "k6 run tests/load/signalling-server.js"
  },
  "keywords": [
    "webrtc",
    "voip",
    "p2p",
    "mesh",
    "socket.io"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "tsconfig-paths": "^4.2.0"
  }
}
